{
  "name": "jackfruit-king",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @jk/db generate",
    "db:push": "pnpm --filter @jk/db push",
    "db:migrate": "pnpm --filter @jk/db migrate",
    "db:seed": "pnpm --filter @jk/db seed",
    "db:studio": "pnpm --filter @jk/db studio",
    "db:reset": "pnpm --filter @jk/db reset",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
